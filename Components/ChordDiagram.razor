@using GuitarChordExplorer.Models

<div class="chord-card @CardClass">
    <div class="chord-roman">@Info.RomanNumeral</div>
    <div class="chord-name-lbl">@Info.ChordName</div>

    @if (Voicing is not null)
    {
        @if (Voicing.BaseFret > 1)
        {
            <div class="fret-badge">@(Voicing.BaseFret)fr</div>
        }
        else
        {
            <div class="fret-badge-placeholder"></div>
        }

        <svg width="165" height="170" viewBox="0 0 165 170" class="chord-svg"
             aria-label="@Info.ChordName chord diagram">

            @if (Voicing.BaseFret == 1)
            {
                <rect x="20" y="33" width="125" height="5" fill="#1a1a2e" rx="1" />
            }
            else
            {
                <line x1="20" y1="33" x2="145" y2="33" stroke="#aaa" stroke-width="1.5" />
            }

            @for (int si = 0; si < 6; si++)
            {
                var sx = 20 + si * 25;
                <line x1="@sx" y1="33" x2="@sx" y2="160" stroke="#bbb" stroke-width="1.5" />
            }

            @for (int fi = 1; fi <= 4; fi++)
            {
                var fy = 33 + fi * 32;
                <line x1="20" y1="@fy" x2="145" y2="@fy" stroke="#ddd" stroke-width="1" />
            }

            @for (int si = 0; si < 6; si++)
            {
                var sx = 20 + si * 25;
                if (Voicing.Frets[si] == -1)
                {
                    <line x1="@(sx - 6)" y1="15" x2="@(sx + 6)" y2="27"
                          stroke="#e74c3c" stroke-width="2" stroke-linecap="round" />
                    <line x1="@(sx + 6)" y1="15" x2="@(sx - 6)" y2="27"
                          stroke="#e74c3c" stroke-width="2" stroke-linecap="round" />
                }
                else if (Voicing.Frets[si] == 0)
                {
                    <circle cx="@sx" cy="21" r="5" fill="none" stroke="#555" stroke-width="1.5" />
                }
            }

            @if (Voicing.BarreFret.HasValue)
            {
                var relPos = Voicing.BarreFret.Value - Voicing.BaseFret + 1;
                var barY   = 33 + (relPos - 1) * 32 + 9;
                var barX1  = 20 + Voicing.BarreFromString * 25;
                var barX2  = 20 + Voicing.BarreToString   * 25;
                var barW   = barX2 - barX1;
                <rect x="@barX1" y="@barY" width="@barW" height="16" fill="#1a1a2e" rx="8" />
            }

            @for (int si = 0; si < 6; si++)
            {
                var fret = Voicing.Frets[si];
                if (fret > 0)
                {
                    bool coveredByBarre = Voicing.BarreFret.HasValue
                        && fret == Voicing.BarreFret.Value
                        && si >= Voicing.BarreFromString
                        && si <= Voicing.BarreToString;

                    if (!coveredByBarre)
                    {
                        var relPos = fret - Voicing.BaseFret + 1;
                        var dotX   = 20 + si * 25;
                        var dotY   = 33 + (relPos - 1) * 32 + 16;
                        <circle cx="@dotX" cy="@dotY" r="9" fill="#1a1a2e" />
                    }
                }
            }
        </svg>

        <div class="string-labels">
            <span>E</span><span>A</span><span>D</span><span>G</span><span>B</span><span>e</span>
        </div>
    }
    else
    {
        <div class="no-diagram">—</div>
    }

    <div class="quality-badge @BadgeClass">@Info.QualityLabel</div>
</div>

@code {
    [Parameter] public required ChordInfo    Info    { get; set; }
    [Parameter] public          ChordVoicing? Voicing { get; set; }

    private string CardClass => Info.Quality switch
    {
        ChordQuality.Major      => "chord-card-major",
        ChordQuality.Minor      => "chord-card-minor",
        ChordQuality.Diminished => "chord-card-dim",
        _                       => ""
    };

    private string BadgeClass => Info.Quality switch
    {
        ChordQuality.Major      => "badge-major",
        ChordQuality.Minor      => "badge-minor",
        ChordQuality.Diminished => "badge-dim",
        _                       => ""
    };
}
